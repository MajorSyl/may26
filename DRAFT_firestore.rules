rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based helper checks (Admins/Officers can be defined in a dedicated list,
    // or we check a specific users/{uid} document's role field)
    function isOfficer() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Club Officer', 'President'];
    }

    // 1. Users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'Rotarian';
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Prevent self-privilege escalation (cannot change role or metrics except via Officer)
        incoming().role == existing().role &&
        incoming().attendanceRate == existing().attendanceRate &&
        incoming().contributionGoals == existing().contributionGoals &&
        incoming().contributedAmount == existing().contributedAmount
      ) || isOfficer();
      allow delete: if isOfficer();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.keys().size() <= 9 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.role is string && data.role in ['Rotarian', 'Club Officer', 'Guest', 'President'] &&
             (!data.keys().hasAny(['attendanceRate']) || data.attendanceRate is number) &&
             (!data.keys().hasAny(['contributionGoals']) || data.contributionGoals is number) &&
             (!data.keys().hasAny(['contributedAmount']) || data.contributedAmount is number) &&
             (!data.keys().hasAny(['committee']) || data.committee is string) &&
             (!data.keys().hasAny(['tasks']) || data.tasks is list);
    }

    // 2. Projects collection
    match /projects/{projectId} {
      allow read: if true; // Public projects directory
      allow create, update: if isOfficer() && isValidProject(incoming());
      allow delete: if isOfficer();
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'description', 'year', 'status']) &&
             data.keys().size() <= 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 100 &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.year is number &&
             data.status is string && data.status in ['Completed', 'Active', 'Planning'] &&
             (!data.keys().hasAny(['impact']) || data.impact is string) &&
             (!data.keys().hasAny(['imageUrl']) || data.imageUrl is string);
    }

    // 3. Events collection
    match /events/{eventId} {
      allow read: if true; // Public listings
      allow create, update: if isOfficer() && isValidEvent(incoming());
      allow delete: if isOfficer();
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'time', 'location', 'type']) &&
             data.keys().size() <= 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 100 &&
             data.date is string &&
             data.time is string &&
             data.location is string && data.location.size() <= 200 &&
             data.type is string && data.type in ['Weekly Meeting', 'Service Project', 'Social', 'Fundraiser'] &&
             (!data.keys().hasAny(['speaker']) || data.speaker is string) &&
             (!data.keys().hasAny(['description']) || data.description is string);
    }

    // 4. Inquiries collection
    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming());
      allow get: if isOfficer();
      allow list: if isOfficer();
      allow update, delete: if isOfficer();
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'message', 'type']) &&
             data.keys().size() <= 7 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 3000 &&
             data.type is string && data.type in ['Membership Inquiry', 'Donation Inquiry', 'General Contact'] &&
             (!data.keys().hasAny(['subject']) || data.subject is string) &&
             (!data.keys().hasAny(['createdAt']) || data.createdAt is string);
    }
  }
}
